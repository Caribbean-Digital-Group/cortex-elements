{
  "name": "cortex-elements",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "build-only": "vite build",
    "type-check": "tsc --noEmit",
    "demo": "npm run build-only && vite --config vite.demo.config.ts",
    "test": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "terser": "^5.46.1",
    "typescript": "~6.0.0",
    "vite": "^8.0.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
